# Copy to .env and fill in. Do not commit .env.
# Used by docker-compose.kimi-k2.6.yml — keep in sync with the YAML `${...}` references.

# Required: Hugging Face token with access to moonshotai/Kimi-K2.6
HF_TOKEN=hf_xxx_replace_me

# Required: master key for LiteLLM Proxy. Clients must send `Authorization: Bearer <this>`.
LITELLM_MASTER_KEY=sk-local-dev-replace-me

# Optional host port overrides
VLLM_HOST_PORT=8000
LITELLM_HOST_PORT=4000
OPEN_WEBUI_HOST_PORT=3000

# Optional: served name for the small vLLM model (vllm-small service)
SERVED_MODEL_NAME=DeepSeek-V4-Flash

# Optional: vLLM GPU memory utilization cap for the small DeepSeek service.
DEEPSEEK_GPU_MEM_UTIL=0.20

# Optional: dummy key passed to OpenWebUI for its OpenAI client
OPENWEBUI_OPENAI_API_KEY=dummy
